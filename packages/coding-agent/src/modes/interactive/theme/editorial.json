{
	"$schema": "https://raw.githubusercontent.com/earendil-works/pi/main/packages/coding-agent/src/modes/interactive/theme/theme-schema.json",
	"name": "editorial",
	"vars": {
		"accent":    "#7B61FF",
		"text":      "#E8E6E0",
		"muted":     "#8B8680",
		"dim":       "#4A4742",
		"success":   "#4FB286",
		"error":     "#E5484D",
		"warning":   "#E5C07B",
		"selBg":     "#2A2620",
		"codeBlock": "#C8C5BF"
	},
	"colors": {
		"accent": "accent",
		"border": "muted",
		"borderAccent": "accent",
		"borderMuted": "dim",
		"success": "success",
		"error": "error",
		"warning": "warning",
		"muted": "muted",
		"dim": "dim",
		"text": "text",
		"thinkingText": "muted",

		"selectedBg": "selBg",
		"userMessageBg": "",
		"userMessageText": "text",
		"customMessageBg": "",
		"customMessageText": "text",
		"customMessageLabel": "accent",
		"toolPendingBg": "",
		"toolSuccessBg": "",
		"toolErrorBg": "",
		"toolTitle": "muted",
		"toolOutput": "text",

		"mdHeading": "text",
		"mdLink": "accent",
		"mdLinkUrl": "dim",
		"mdCode": "accent",
		"mdCodeBlock": "codeBlock",
		"mdCodeBlockBorder": "dim",
		"mdQuote": "muted",
		"mdQuoteBorder": "dim",
		"mdHr": "muted",
		"mdListBullet": "accent",

		"toolDiffAdded": "success",
		"toolDiffRemoved": "error",
		"toolDiffContext": "muted",

		"syntaxComment": "muted",
		"syntaxKeyword": "accent",
		"syntaxFunction": "#7BA7E5",
		"syntaxVariable": "text",
		"syntaxString": "success",
		"syntaxNumber": "warning",
		"syntaxType": "#7BA7E5",
		"syntaxOperator": "text",
		"syntaxPunctuation": "muted",

		"thinkingOff": "dim",
		"thinkingMinimal": "muted",
		"thinkingLow": "#5A8A8A",
		"thinkingMedium": "#7BA7E5",
		"thinkingHigh": "accent",
		"thinkingXhigh": "#C77BE5",

		"bashMode": "warning"
	},
	"glyphs": {
		"hr": "─",
		"bullet1": "·",
		"bullet2": "‣",
		"middleDot": " · ",
		"ellipsis": "…",
		"submitHint": "⏎",
		"spinnerFrames": [".  ", ".. ", "..."],
		"spinnerIntervalMs": 400,
		"toolDots": "·",
		"successPill": "ok",
		"errorPill": "fail",
		"workingLabel": "thinking"
	},
	"layout": {
		"messageStyle": "rule",
		"toolBlockStyle": "indent",
		"inputAreaStyle": "rules-only",
		"roleLabelStyle": "smallcaps",
		"userRoleLabel": "You",
		"assistantRoleLabel": "Claude",
		"toolGutter": 4,
		"blankLineBetweenTurns": 1,
		"footerStyle": "single-line",
		"footerSeparator": "   ",
		"asciiOnly": false
	},
	"export": {
		"pageBg": "#15130F",
		"cardBg": "#1C1A16",
		"infoBg": "#28241C"
